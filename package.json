{
  "name": "@screepts/screeps-api",
  "version": "1.1.0",
  "description": "A JavaScript API client for the Screeps World server",
  "license": "ISC",
  "contributors": [
    {
      "name": "Adam Shumann"
    },
    {
      "name": "Shu"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/screepts/screeps-api.git"
  },
  "bin": {
    "screeps-api": "bin/screeps-api.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "node --run build",
    "lint": "oxlint --type-check --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test:e2e": "vitest run --typecheck",
    "test": "node --run fmt:check && node --run lint"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^14.0.3",
    "debug": "^4.4.3",
    "eventemitter3": "^5.0.4",
    "js-yaml": "^4.1.1",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/pako": "^2.0.4",
    "oxfmt": ">=0.40.0 <2.0.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": ">=0.17.0 <2.0.0",
    "tsdown": ">=0.21.1 <2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=21.0.0"
  }
}
